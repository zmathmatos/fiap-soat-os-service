{
  "name": "fiap-soat-tech-challenge-app",
  "version": "0.0.1",
  "description": "Project for the FIAP Tech Challenge - Unit 2.",
  "main": "src/server.ts",
  "type": "commonjs",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "migrate": "sequelize-cli db:migrate",
    "seed": "sequelize-cli db:seed:all",
    "docker": "docker compose up -d",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:watch": "docker compose up",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose down && docker compose up -d",
    "dev": "nodemon src/server.ts --watch 'src/' -e ts",
    "prebuild": "rimraf dist",
    "build": "etsc -p tsconfig.build.json",
    "compile": "npx tsc",
    "start": "node -r newrelic ./dist/server.js",
    "test": "jest --runInBand --silent",
    "test:unit": "jest --silent --testPathIgnorePatterns \"\\.integration\\.\"",
    "test:integration": "jest --runInBand --silent --testPathPattern=\\.integration\\.test.ts$",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage --silent",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zmathmatos/fiap-soat-tech-challenge.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zmathmatos/fiap-soat-tech-challenge/issues"
  },
  "homepage": "https://github.com/zmathmatos/fiap-soat-tech-challenge#readme",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "newrelic": "^12.5.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "pino": "^9.5.0",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/newrelic": "^9.14.5",
    "@types/node": "^25.0.3",
    "@types/validator": "^13.15.10",
    "esbuild": "^0.27.3",
    "esbuild-node-tsc": "^2.0.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },

  "overrides": {
    "glob": "^9.0.0"
  }
}
