DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

APP_PORT=3000

JWT_SECRET=my-jwt-secret-key
JWT_EXPIRES_IN=24h

BILLING_SERVICE_URL=http://fiap-billing:3001

# RabbitMQ (broker runs in this repo's docker-compose.dev.yml, shared via the fiap-net network)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=payment-events
RABBITMQ_QUEUE=os-service.payment-events

# AWS and Kubernetes configuration to manually deploy the app
AWS_REGION=<your-aws-region>
ECR_REPOSITORY=<your-ecr-repo-name>
EKS_CLUSTER_NAME=<your-cluster-name>
K8S_NAMESPACE=fiap-tech-challenge
APP_NAME=fiap-soat-tech-challenge-app