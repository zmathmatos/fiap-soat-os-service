flowchart TB
    subgraph CI["Integração Contínua — executa a cada push ou Pull Request"]
        PUSH["Novo código enviado\n(push ou PR nas branches master/develop)"]
        TEST["Executa testes automatizados\n(Jest com banco PostgreSQL temporário)"]
        SONAR["Análise de qualidade de código\n(SonarCloud — cobertura e vulnerabilidades)"]
        BUILD["Compilação TypeScript\n(gera artefato de distribuição)"]

        PUSH --> TEST
        TEST --> SONAR
        TEST --> BUILD
    end

    subgraph CD["Entrega Contínua — executa manualmente via GitHub Actions"]
        ECR_LOGIN["Autenticação no repositório de imagens\n(Amazon ECR)"]
        DOCKER_B["Construção da imagem Docker"]
        DOCKER_P["Publicação da imagem no ECR\n(tags: hash do commit + latest)"]
        KUBE["Conexão com o cluster EKS"]
        NS["Cria namespace se não existir"]
        CM2["Aplica configurações no cluster\n(ConfigMap)"]
        SEC2["Aplica credenciais no cluster\n(Secret)"]
        DEL_JOB["Remove migração anterior"]
        APPLY_ALL["Aplica todos os manifestos Kubernetes\n(migração, deployment, serviço, HPA)"]
        WAIT_JOB["Aguarda conclusão da migração do banco\n(timeout: 5 min)"]
        WAIT_ROLL["Aguarda deploy estabilizar\n(timeout: 5 min)"]
        DONE["Deploy concluído"]

        ECR_LOGIN --> DOCKER_B
        DOCKER_B --> DOCKER_P
        DOCKER_P --> KUBE
        KUBE --> NS
        NS --> CM2
        CM2 --> SEC2
        SEC2 --> DEL_JOB
        DEL_JOB --> APPLY_ALL
        APPLY_ALL --> WAIT_JOB
        WAIT_JOB --> WAIT_ROLL
        WAIT_ROLL --> DONE
    end

    BUILD -->|"CI aprovado — disparar CD manualmente"| ECR_LOGIN
    TEST -->|"falhou"| FAIL["Notifica falha — deploy bloqueado"]

    style CI fill:#e8f5e9
    style CD fill:#e3f2fd
    style FAIL fill:#ffebee
