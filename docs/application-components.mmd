---
config:
  layout: dagre
---
flowchart TB
    subgraph Dominio["Camada de Domínio"]
        subgraph Entidades["Entidades de Negócio"]
            USER["Usuário"]
            VEHICLE["Veículo"]
            SERVICE["Serviço"]
            PART["Peça"]
            SO["Ordem de Serviço"]
            DOC["Documento"]
        end
        REPO_INT["Contratos de Repositório\n(interfaces)"]
    end

    subgraph Aplicacao["Camada de Aplicação"]
        UC["Casos de Uso\n(regras de negócio)"]
        AUTH_SVC["Serviço de Autenticação\n(validação JWT)"]
    end

    subgraph Interface["Camada de Interface"]
        CTRL["Controladores"]
        MW["Middlewares\n(auth, admin)"]
        PRES["Apresentadores\n(formatação de resposta)"]
    end

    subgraph Infraestrutura["Camada de Infraestrutura"]
        subgraph Web["Servidor Web (Express)"]
            ROUTE_HEALTH["Rota: /health"]
            ROUTE_AUTH["Rota: /auth"]
            ROUTE_ADM["Rotas Administrativas\n/admin/users, /vehicles,\n/parts, /services, /service-orders"]
            ROUTE_CUST["Rotas do Cliente\n/customer/service-orders"]
        end
        REPO_IMPL["Implementações de Repositório"]
        ORM["Mapeamento Objeto-Relacional\n(Sequelize)"]
        POSTGRES[("Banco de Dados\nPostgreSQL")]
    end

    Entidades --> REPO_INT
    REPO_INT --> UC
    UC --> AUTH_SVC
    UC --> CTRL
    CTRL --> MW
    CTRL --> PRES
    Web --> CTRL
    REPO_IMPL --> ORM
    ORM --> POSTGRES
    UC --> REPO_IMPL

    style Dominio fill:#e1f5fe
    style Aplicacao fill:#fff3e0
    style Interface fill:#e8f5e9
    style Infraestrutura fill:#f3e5f5
    style Web fill:#ede7f6
